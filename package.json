{
  "name": "ai-overlay-stealth",
  "version": "2.0.0",
  "main": "stealth-main.js",
  "scripts": {
    "start": "electron . --disable-gpu",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "screenshot-desktop": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.runtime.host",
    "productName": "Windows Runtime Host",
    "executableName": "RuntimeBrokerHelper",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/screenshot-desktop/**"
    ],
    "win": {
      "target": [
        {
          "target": "dir"
        }
      ],
      "icon": "assets/app-icon.ico",
      "signtoolOptions": null
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "assets/tray-icon.png",
        "to": "tray-icon.png"
      }
    ],
    "files": [
      "stealth-main.js",
      "gemini-ui.html",
      "cropper.html",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/.cache/**"
    ]
  }
}
